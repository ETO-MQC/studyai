# Optional server-side AI fallback. Browser settings can override these per request.
AI_PROVIDER_KIND=openai-compatible
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_AUTH_HEADER_NAME=Authorization
AI_AUTH_HEADER_PREFIX=Bearer
# AI_EXTRA_HEADERS=Header-Name: value

# Backward-compatible OpenAI env names are still supported.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
